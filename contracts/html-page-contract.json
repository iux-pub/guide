{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "INFOUX HTML Page Contract",
  "version": 1,
  "description": "에이전트가 페이지 HTML을 생성할 때 반드시 따르는 공통 page shell 계약.",
  "requiredLandmarks": [
    {
      "selector": "a.skip-to-content[href=\"#main\"]",
      "rule": "R-14",
      "message": "body 최상단 본문 바로가기 링크"
    },
    {
      "selector": "header#header",
      "rule": "R-15",
      "message": "공통 헤더 랜드마크"
    },
    {
      "selector": "main#main",
      "rule": "R-15",
      "message": "본문 바로가기 대상 main 랜드마크"
    },
    {
      "selector": "footer#footer",
      "rule": "R-15",
      "message": "공통 푸터 랜드마크"
    }
  ],
  "main": {
    "maxCount": 1,
    "id": "main",
    "directChildTag": "section",
    "sectionRequires": [
      "container",
      "accessibleName"
    ]
  },
  "sectionArchetypes": [
    "intro",
    "content",
    "list",
    "form",
    "data",
    "search",
    "process",
    "notice"
  ],
  "notes": [
    "section modifier는 목적 기반으로만 사용한다: section--intro, section--content, section--list 등.",
    "section은 heading 또는 aria-labelledby/aria-label로 접근 가능한 이름을 가진다.",
    "컴포넌트화는 전체 페이지가 아니라 main 내부 section 단위로 한다."
  ]
}
