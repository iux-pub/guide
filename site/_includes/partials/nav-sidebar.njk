<aside class="docs-layout__sidebar" id="sidebar" role="navigation" aria-label="문서 탐색">
  <nav class="docs-nav">
    <a href="/" class="docs-nav__brand">
      <span class="docs-nav__brand-title">{{ site.title }}</span>
      <span class="docs-nav__brand-version">{{ site.version }}</span>
    </a>
    {% include "partials/search.njk" %}
    {% for section in navigation.sections %}
    {% set sectionHasActive = false %}
    {% for item in section.items %}
      {% if page.url == item.url %}
        {% set sectionHasActive = true %}
      {% endif %}
    {% endfor %}
    <details class="docs-nav__section" {% if sectionHasActive %}open{% endif %}>
      <summary class="docs-nav__title">{{ section.title }}</summary>
      <ul class="docs-nav__list">
        {% for item in section.items %}
        <li class="docs-nav__item">
          <a href="{{ item.url }}" class="docs-nav__link{% if page.url == item.url %} docs-nav__link--active{% endif %}" {% if page.url == item.url %}aria-current="page"{% endif %}>
            {{ item.title }}
          </a>
        </li>
        {% endfor %}
      </ul>
    </details>
    {% endfor %}
  </nav>
</aside>
