{% extends "layouts/base.njk" %}

{% block content %}
<h1>{{ title }}</h1>

{% if playground_src %}
<div class="preview">
  <div class="preview__frame">
    <iframe
      src="{{ playground_src }}"
      title="{{ title }} 컴포넌트 미리보기"
      height="{{ preview_height | default(400) }}"
      loading="lazy"
      class="preview__iframe"
    ></iframe>
  </div>
</div>
{% endif %}

{{ content | safe }}
{% endblock %}
