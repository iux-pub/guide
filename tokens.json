{
  "color": {
    "primary": { "$value": "#256ef4", "$type": "color" },
    "primary-light": { "$value": "#6a9df7", "$type": "color" },
    "primary-dark": { "$value": "#083891", "$type": "color" },
    "gray-900": { "$value": "#222", "$type": "color" },
    "gray-800": { "$value": "#333", "$type": "color" },
    "gray-700": { "$value": "#555", "$type": "color" },
    "gray-600": { "$value": "#666", "$type": "color" },
    "gray-500": { "$value": "#999", "$type": "color" },
    "gray-400": { "$value": "#b1b8be", "$type": "color" },
    "gray-300": { "$value": "#ccc", "$type": "color" },
    "gray-200": { "$value": "#ddd", "$type": "color" },
    "gray-100": { "$value": "#efefef", "$type": "color" },
    "gray-50": { "$value": "#f8f8f8", "$type": "color" },
    "danger": { "$value": "#de3412", "$type": "color" },
    "warning": { "$value": "#c78500", "$type": "color" },
    "success": { "$value": "#228738", "$type": "color" },
    "info": { "$value": "#0b78cb", "$type": "color" },
    "text": { "$value": "#1e2124", "$type": "color" },
    "text-secondary": { "$value": "#666", "$type": "color" },
    "text-disabled": { "$value": "#999", "$type": "color" },
    "bg": { "$value": "#fff", "$type": "color" },
    "bg-secondary": { "$value": "#f8f8f8", "$type": "color" },
    "border": { "$value": "#ccc", "$type": "color" },
    "border-light": { "$value": "#efefef", "$type": "color" },
    "white": { "$value": "#fff", "$type": "color" },
    "black": { "$value": "#000", "$type": "color" },
    "primary-alpha-8": { "$value": "color-mix(in srgb, var(--color-primary) 8%, transparent)", "$type": "color", "$description": "Primary 8% 투명도 — 코드 뱃지 배경 등" },
    "primary-alpha-6": { "$value": "color-mix(in srgb, var(--color-primary) 6%, transparent)", "$type": "color", "$description": "Primary 6% 투명도 — 활성 항목 배경 등" },
    "black-alpha-50": { "$value": "color-mix(in srgb, var(--color-black) 50%, transparent)", "$type": "color", "$description": "Black 50% 투명도 — 모달 backdrop" }
  },
  "typography": {
    "font-family": {
      "base": { "$value": "'Pretendard GOV', 'Malgun Gothic', 'apple sd gothic neo', sans-serif", "$type": "fontFamily" }
    },
    "font-size": {
      "2xl": { "$value": "3.2rem", "$type": "dimension" },
      "xl": { "$value": "2.8rem", "$type": "dimension" },
      "lg": { "$value": "2.4rem", "$type": "dimension" },
      "md": { "$value": "2rem", "$type": "dimension" },
      "base": { "$value": "1.6rem", "$type": "dimension" },
      "sm": { "$value": "1.4rem", "$type": "dimension" },
      "xs": { "$value": "1.2rem", "$type": "dimension" }
    },
    "font-weight": {
      "regular": { "$value": "400", "$type": "number" },
      "medium": { "$value": "500", "$type": "number" },
      "semibold": { "$value": "600", "$type": "number" },
      "bold": { "$value": "700", "$type": "number" }
    },
    "leading": {
      "tight": { "$value": "1.2", "$type": "number" },
      "base": { "$value": "1.6", "$type": "number" },
      "loose": { "$value": "1.8", "$type": "number" }
    }
  },
  "spacing": {
    "xs": { "$value": "0.4rem", "$type": "dimension" },
    "sm": { "$value": "0.8rem", "$type": "dimension" },
    "md": { "$value": "1.6rem", "$type": "dimension" },
    "lg": { "$value": "2.4rem", "$type": "dimension" },
    "xl": { "$value": "3.2rem", "$type": "dimension" },
    "2xl": { "$value": "4.8rem", "$type": "dimension" },
    "3xl": { "$value": "6.4rem", "$type": "dimension" }
  },
  "grid": {
    "columns": {
      "mobile": { "$value": "4", "$type": "number" },
      "tablet": { "$value": "12", "$type": "number" }
    },
    "gutter": {
      "mobile": { "$value": "16px", "$type": "dimension" },
      "tablet": { "$value": "24px", "$type": "dimension" }
    },
    "margin": {
      "mobile": { "$value": "16px", "$type": "dimension" },
      "tablet": { "$value": "24px", "$type": "dimension" },
      "pc": { "$value": "40px", "$type": "dimension" }
    },
    "container-max-width": {
      "mobile": { "$value": "100%", "$type": "dimension" },
      "pc": { "$value": "1200px", "$type": "dimension" }
    },
    "$description": "KRDS 표준형 기반. 브레이크포인트: 모바일(0~767px), 태블릿(768px~1279px), PC(1280px~)"
  },
  "radius": {
    "sm": { "$value": "4px", "$type": "dimension" },
    "base": { "$value": "8px", "$type": "dimension" },
    "lg": { "$value": "12px", "$type": "dimension" },
    "xl": { "$value": "16px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "shadow": {
    "sm": { "$value": "0 1px 2px rgb(0 0 0 / 5%)", "$type": "shadow" },
    "base": { "$value": "0 1px 3px rgb(0 0 0 / 10%), 0 1px 2px rgb(0 0 0 / 6%)", "$type": "shadow" },
    "lg": { "$value": "0 10px 15px rgb(0 0 0 / 10%), 0 4px 6px rgb(0 0 0 / 5%)", "$type": "shadow" }
  },
  "transition": {
    "fast": { "$value": "0.1s ease", "$type": "transition" },
    "base": { "$value": "0.3s ease", "$type": "transition" },
    "slow": { "$value": "0.5s ease", "$type": "transition" }
  },
  "z-index": {
    "dropdown": { "$value": "100", "$type": "number" },
    "sticky": { "$value": "200", "$type": "number" },
    "fixed": { "$value": "300", "$type": "number" },
    "modal-backdrop": { "$value": "400", "$type": "number" },
    "modal": { "$value": "500", "$type": "number" },
    "toast": { "$value": "600", "$type": "number" }
  }
}
